# Copy this to .env for LOCAL testing only. The cloud run gets these from the
# GitHub Actions workflow + repository secrets instead (see README).
# .env is git-ignored so your password never leaves your computer.

# --- What to search ---
ORIGIN=TLV
DESTINATION=AUS
DATE_START=2026-07-21
DATE_END=2026-08-03
CURRENT_DEPARTURE_DATE=2026-08-04
PASSENGERS=1

# --- Alert tuning (keep the noise down) ---
MAX_STOPS=2
# MAX_PRICE=1500          # optional ceiling; leave commented for no limit
TOP_PER_DATE=3
PRICE_DROP_THRESHOLD=25
PREFER_ELAL=true

# --- Email (the only channel that needs a secret) ---
NOTIFY_CHANNEL=email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ozertom@gmail.com
EMAIL_FROM=ozertom@gmail.com
EMAIL_TO=ozertom@gmail.com,amitozer@gmail.com
# SMTP_PASSWORD is a Gmail App Password. Locally, put it here. In the cloud it
# lives in a GitHub secret and is NOT written in this file.
SMTP_PASSWORD=
